<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NexoManager — Admin</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07090F;--bg2:#0B0D16;--bg3:#0F1219;
  --b:rgba(255,255,255,.06);--b2:rgba(255,255,255,.1);
  --bl:#4A9EFF;--gr:#00C896;--re:#FF4D6A;--am:#FFB800;--pu:#A78BFA;
  --t:#E0E8F4;--t2:#6A7890;--t3:#3A4260;
  --fm:'DM Mono',monospace;--fd:'Syne',sans-serif;--fb:'DM Sans',sans-serif;
}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--t);font-family:var(--fb)}

/* LOGIN */
#LS{position:fixed;inset:0;z-index:999;background:var(--bg);display:flex;align-items:center;justify-content:center}
.lb{background:var(--bg2);border:1px solid var(--b);border-radius:20px;padding:48px 44px;width:340px;text-align:center;box-shadow:0 40px 80px rgba(0,0,0,.7)}
.lt{font-family:var(--fd);font-size:22px;font-weight:800;letter-spacing:-.03em;margin:16px 0 6px}
.ls{font-size:13px;color:var(--t2);margin-bottom:28px}
.li{width:100%;background:var(--bg);border:1px solid var(--b2);border-radius:10px;padding:12px 16px;font-family:var(--fm);font-size:14px;color:var(--t);outline:none;margin-bottom:10px;display:block;transition:border-color .2s}
.li:focus{border-color:var(--bl)}
.lb-btn{width:100%;background:var(--bl);color:#fff;border:none;border-radius:10px;padding:13px;font-family:var(--fd);font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 0 30px rgba(74,158,255,.25)}
.lb-btn:hover{background:#5AADFF}
.le{font-size:12px;color:var(--re);margin-top:8px;display:none;font-family:var(--fm)}

/* APP */
#APP{display:none;flex-direction:column;height:100vh}
.tb{display:flex;align-items:center;justify-content:space-between;padding:0 22px;height:50px;flex-shrink:0;background:rgba(7,9,15,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--b)}
.tbl{display:flex;align-items:center;gap:10px}
.tbn{font-family:var(--fd);font-size:15px;font-weight:800;letter-spacing:-.03em}
.badge{font-family:var(--fm);font-size:10px;border-radius:100px;padding:2px 9px;letter-spacing:.05em}
.ba{color:var(--bl);background:rgba(74,158,255,.1);border:1px solid rgba(74,158,255,.2)}
.bl2{color:var(--gr);background:rgba(0,200,150,.1);border:1px solid rgba(0,200,150,.2);display:flex;align-items:center;gap:5px}
.ld{width:6px;height:6px;background:var(--gr);border-radius:50%;box-shadow:0 0 6px var(--gr);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.tbr{display:flex;align-items:center;gap:8px}
.btn{border-radius:8px;padding:5px 12px;font-family:var(--fm);font-size:11px;cursor:pointer;transition:all .2s}
.btn-bl{background:rgba(74,158,255,.1);color:var(--bl);border:1px solid rgba(74,158,255,.2)}
.btn-bl:hover{background:rgba(74,158,255,.2)}
.btn-lo{background:transparent;color:var(--t3);border:1px solid var(--b)}
.btn-lo:hover{border-color:var(--re);color:var(--re)}
.upd{font-family:var(--fm);font-size:10px;color:var(--t3)}

/* SCROLL */
.dash{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:14px}
.dash::-webkit-scrollbar{width:4px}
.dash::-webkit-scrollbar-thumb{background:var(--b2);border-radius:2px}

/* CARDS */
.r4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.r2{display:grid;grid-template-columns:1.5fr 1fr;gap:12px}
.r3{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:12px}
.card{background:var(--bg2);border:1px solid var(--b);border-radius:14px;padding:16px 18px;position:relative;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--b2)}
.ca::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--ac,var(--bl)),transparent);opacity:.6}
.sl{font-family:var(--fm);font-size:10px;color:var(--t2);letter-spacing:.07em;text-transform:uppercase;margin-bottom:8px}
.sv{font-family:var(--fd);font-size:32px;font-weight:800;letter-spacing:-.03em;line-height:1;margin-bottom:4px}
.ss{font-size:11px;color:var(--t3);font-family:var(--fm)}
.si{position:absolute;top:14px;right:14px;font-size:18px;opacity:.25}
.ct{font-family:var(--fd);font-size:14px;font-weight:700;letter-spacing:-.02em;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.cts{font-family:var(--fm);font-size:10px;color:var(--t3);font-weight:400}

/* GLOBE */
#gw{position:relative;width:100%;height:320px;min-height:320px}
#gc{width:100%!important;height:100%!important;cursor:grab;display:block}
#gc:active{cursor:grabbing}
.go{position:absolute;bottom:12px;left:14px;font-family:var(--fm);font-size:10px;color:var(--t3);display:flex;align-items:center;gap:14px}
.gl{display:flex;align-items:center;gap:5px}
.gld{width:6px;height:6px;border-radius:50%}
#gcnt{position:absolute;top:12px;right:14px;font-family:var(--fm);font-size:11px;color:var(--t2);background:rgba(7,9,15,.8);border:1px solid var(--b);border-radius:8px;padding:3px 10px}

/* CHART */
.cw{position:relative;height:170px}

/* TABLE */
.dt{width:100%;border-collapse:collapse}
.dt th{font-family:var(--fm);font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.08em;padding:8px 12px;text-align:left;border-bottom:1px solid var(--b);white-space:nowrap}
.dt td{padding:8px 12px;font-size:12px;color:var(--t2);border-bottom:1px solid rgba(255,255,255,.02);font-family:var(--fm);white-space:nowrap;max-width:140px;overflow:hidden;text-overflow:ellipsis}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:rgba(74,158,255,.03)}
.pill{border-radius:100px;padding:2px 8px;font-size:10px;font-family:var(--fm)}
.pb{background:rgba(74,158,255,.12);color:var(--bl)}
.pg{background:rgba(0,200,150,.12);color:var(--gr)}
.pr{background:rgba(255,77,106,.12);color:var(--re)}

/* BARS */
.bi{display:flex;align-items:center;gap:10px;margin-bottom:11px}
.bi:last-child{margin-bottom:0}
.bn{font-size:12px;color:var(--t2);font-family:var(--fm);min-width:100px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bt{flex:1;height:5px;background:rgba(255,255,255,.05);border-radius:100px;overflow:hidden}
.bf{height:100%;border-radius:100px;transition:width 1s cubic-bezier(.23,1,.32,1)}
.bp{font-family:var(--fm);font-size:10px;color:var(--t3);min-width:32px;text-align:right}

/* EMPTY */
.empty{padding:24px;font-family:var(--fm);font-size:11px;color:var(--t3);text-align:center}
</style>
</head>
<body>

<div id="LS">
  <div class="lb">
    <div style="font-size:32px">🔐</div>
    <div class="lt">Admin Dashboard</div>
    <div class="ls">NexoManager — Accès restreint</div>
    <input class="li" type="password" id="pi" placeholder="Mot de passe admin">
    <button class="lb-btn" onclick="doLogin()">Accéder</button>
    <div class="le" id="le">Mot de passe incorrect</div>
  </div>
</div>

<div id="APP">
  <div class="tb">
    <div class="tbl">
      <span style="font-size:16px">🔐</span>
      <span class="tbn">NexoManager</span>
      <span class="badge ba">ADMIN</span>
      <span class="badge bl2"><span class="ld"></span>LIVE</span>
    </div>
    <div class="tbr">
      <span class="upd" id="upd">—</span>
      <button class="btn btn-bl" onclick="loadAll()">↻ Actualiser</button>
      <button class="btn btn-lo" onclick="logout()">Déconnexion</button>
      <button class="btn" style="background:rgba(255,77,106,.1);color:#FF4D6A;border:1px solid rgba(255,77,106,.2)" onclick="window.parent.closeAdminOverlay()">✕ Fermer</button>
    </div>
  </div>

  <div class="dash">

    <!-- Stats -->
    <div class="r4">
      <div class="card ca" style="--ac:var(--bl)"><div class="si">👥</div><div class="sl">Utilisateurs uniques</div><div class="sv" id="su" style="color:var(--bl)">0</div><div class="ss">machines distinctes</div></div>
      <div class="card ca" style="--ac:var(--gr)"><div class="si">🚀</div><div class="sl">Total lancements</div><div class="sv" id="st" style="color:var(--gr)">0</div><div class="ss">depuis le début</div></div>
      <div class="card ca" style="--ac:var(--am)"><div class="si">📅</div><div class="sl">Aujourd'hui</div><div class="sv" id="sd" style="color:var(--am)">0</div><div class="ss">lancements ce jour</div></div>
      <div class="card ca" style="--ac:var(--pu)"><div class="si">🌍</div><div class="sl">Pays différents</div><div class="sv" id="sc" style="color:var(--pu)">0</div><div class="ss">pays dans le monde</div></div>
    </div>

    <!-- Globe + Chart -->
    <div class="r2">
      <div class="card" style="padding:0;overflow:hidden">
        <div id="gw">
          <canvas id="gc"></canvas>
          <div id="gcnt">0 pays actifs</div>
          <canvas id="glabels" style="position:absolute;inset:0;pointer-events:none;width:100%;height:100%"></canvas>
          <div class="go">
            <div class="gl"><div class="gld" style="background:var(--bl);box-shadow:0 0 6px var(--bl)"></div>Utilisateur</div>
            <div class="gl"><div class="gld" style="background:var(--gr);box-shadow:0 0 6px var(--gr)"></div>Récent (24h)</div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="ct">Lancements / jour <span class="cts">30 JOURS</span></div>
        <div class="cw"><canvas id="cd"></canvas></div>
      </div>
    </div>

    <!-- Table + Countries + OS -->
    <div class="r3">
      <div class="card" style="padding:0;overflow:hidden">
        <div style="padding:12px 16px 10px;border-bottom:1px solid var(--b);display:flex;align-items:center;justify-content:space-between">
          <span style="font-family:var(--fd);font-size:14px;font-weight:700">Derniers lancements</span>
          <span id="tc" style="font-family:var(--fm);font-size:10px;color:var(--t3)">0 total</span>
        </div>
        <div style="overflow-y:auto;max-height:240px" id="tw">
          <div class="empty">Chargement…</div>
        </div>
      </div>
      <div class="card">
        <div class="ct">Pays <span class="cts">TOP 6</span></div>
        <div id="cl"><div class="empty">Chargement…</div></div>
      </div>
      <div class="card">
        <div class="ct">OS &amp; RAM <span class="cts">RÉPARTITION</span></div>
        <div id="ol"><div class="empty">Chargement…</div></div>
      </div>
    </div>

    <!-- Detail table -->
    <div class="card" style="padding:0;overflow:hidden;min-height:200px">
      <div style="padding:12px 16px 10px;border-bottom:1px solid var(--b);display:flex;align-items:center;justify-content:space-between">
        <span style="font-family:var(--fd);font-size:14px;font-weight:700">Profil utilisateurs — toutes les infos</span>
        <span style="font-family:var(--fm);font-size:10px;color:var(--t3)">hostname · username · IP · RAM · CPU · langue</span>
      </div>
      <div style="overflow-x:auto;overflow-y:auto;max-height:320px" id="dl"><div class="empty">Chargement…</div></div>
    </div>

  </div>
</div>

<script>
const SB_URL = 'https://acjvbmbtojybmggwuvdf.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFjanZibWJ0b2p5Ym1nZ3d1dmRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcyMjkwNDgsImV4cCI6MjA5MjgwNTA0OH0.pCvOzeYEAA6ksbokQWx3yJoeuMPtvpY2Hyd21jhEwQk';
const PWD = 'nexo2025';

const FLAGS = {FR:'🇫🇷',US:'🇺🇸',GB:'🇬🇧',DE:'🇩🇪',BE:'🇧🇪',CA:'🇨🇦',AU:'🇦🇺',NL:'🇳🇱',ES:'🇪🇸',IT:'🇮🇹',CH:'🇨🇭',PT:'🇵🇹',SE:'🇸🇪',PL:'🇵🇱',RU:'🇷🇺',JP:'🇯🇵',CN:'🇨🇳',BR:'🇧🇷',MX:'🇲🇽',MA:'🇲🇦',DZ:'🇩🇿',TN:'🇹🇳',SN:'🇸🇳',IN:'🇮🇳',KR:'🇰🇷',TR:'🇹🇷',SA:'🇸🇦',AE:'🇦🇪',LU:'🇱🇺',AT:'🇦🇹',CZ:'🇨🇿',RO:'🇷🇴',GR:'🇬🇷',FI:'🇫🇮',DK:'🇩🇰',NO:'🇳🇴',IE:'🇮🇪',NZ:'🇳🇿',SG:'🇸🇬',ZA:'🇿🇦',NG:'🇳🇬',EG:'🇪🇬'};

const COORDS = {FR:[46.2,2.2],US:[37.1,-95.7],GB:[55.4,-3.4],DE:[51.2,10.5],BE:[50.5,4.5],CA:[56.1,-106.3],AU:[-25.3,133.8],NL:[52.1,5.3],ES:[40.5,-3.7],IT:[41.9,12.6],CH:[46.8,8.2],PT:[39.4,-8.2],SE:[60.1,18.6],PL:[51.9,19.1],RU:[61.5,105.3],JP:[36.2,138.3],CN:[35.9,104.2],BR:[-14.2,-51.9],MX:[23.6,-102.6],MA:[31.8,-7.1],DZ:[28.0,1.7],TN:[33.9,9.5],SN:[14.5,-14.5],IN:[20.6,78.9],KR:[35.9,127.8],TR:[38.9,35.2],SA:[23.9,45.1],AE:[23.4,53.8],LU:[49.8,6.1],AT:[47.5,14.6],CZ:[49.8,15.5],RO:[45.9,24.9],GR:[39.1,21.8],FI:[61.9,25.7],DK:[56.3,9.5],NO:[60.5,8.5],IE:[53.4,-8.2],NZ:[-40.9,174.9],SG:[1.4,103.8],ZA:[-29.0,25.1],NG:[9.1,8.7],EG:[26.8,30.8],NL:[52.1,5.3],HU:[47.2,19.5]};

// LOGIN
function doLogin(){
  if(document.getElementById('pi').value===PWD){
    document.getElementById('LS').style.display='none';
    document.getElementById('APP').style.display='flex';
    // Re-init globe now that app is visible and has real dimensions
    setTimeout(()=>{
      if(!gRen) {
        initGlobe();
      } else {
        const wrap=document.getElementById('gw');
        const W=wrap.clientWidth, H=wrap.clientHeight||320;
        gCam.aspect=W/H; gCam.updateProjectionMatrix();
        gRen.setSize(W,H);
      }
    }, 100);
    loadAll();
    setInterval(loadAll,30000);
  } else {
    const e=document.getElementById('le');
    e.style.display='block';
    document.getElementById('pi').value='';
    setTimeout(()=>e.style.display='none',3000);
  }
}
function logout(){
  document.getElementById('LS').style.display='flex';
  document.getElementById('APP').style.display='none';
}
document.getElementById('pi').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin();});
window.addEventListener('load',()=>document.getElementById('pi').focus());

// FETCH
async function sb(ep){
  try{
    const r=await fetch(SB_URL+'/rest/v1/'+ep,{headers:{'apikey':SB_KEY,'Authorization':'Bearer '+SB_KEY}});
    const d=await r.json();
    return Array.isArray(d)?d:[];
  }catch(e){console.error('fetch error',e);return[];}
}

// LOAD
let chartD=null;
async function loadAll(){
  const data=await sb('launches?select=*&order=launched_at.desc&limit=2000');
  if(!data||!data.length){
    ['su','st','sd','sc'].forEach(id=>document.getElementById(id).textContent='0');
    document.getElementById('tw').innerHTML='<div class="empty">Aucun lancement enregistré</div>';
    document.getElementById('cl').innerHTML='<div class="empty">Aucune donnée</div>';
    document.getElementById('ol').innerHTML='<div class="empty">Aucune donnée</div>';
    document.getElementById('dl').innerHTML='<div class="empty">Aucune donnée</div>';
    return;
  }
  doStats(data);
  doChart(data);
  doTable(data);
  doCountries(data);
  doOS(data);
  doDetail(data);
  doGlobe(data);
  document.getElementById('upd').textContent='Actualisé '+new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}

// STATS
function doStats(d){
  const users=new Set(d.map(r=>r.user_id)).size;
  const today=new Date().toISOString().slice(0,10);
  const tod=d.filter(r=>r.launched_at&&r.launched_at.startsWith(today)).length;
  const ctries=new Set(d.map(r=>r.country_code).filter(Boolean)).size;
  anim('su',users);anim('st',d.length);anim('sd',tod);anim('sc',ctries);
}
function anim(id,to){
  const el=document.getElementById(id);
  const from=parseInt(el.textContent)||0;
  const t0=performance.now();
  const tick=now=>{
    const p=Math.min((now-t0)/700,1);
    el.textContent=Math.round(from+(to-from)*(1-Math.pow(1-p,3)));
    if(p<1)requestAnimationFrame(tick);
  };
  requestAnimationFrame(tick);
}

// CHART
function doChart(d){
  const days={};
  for(let i=29;i>=0;i--){const dt=new Date();dt.setDate(dt.getDate()-i);days[dt.toISOString().slice(0,10)]=0;}
  d.forEach(r=>{const k=r.launched_at?r.launched_at.slice(0,10):'';if(k in days)days[k]++;});
  const labels=Object.keys(days).map(k=>new Date(k).toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'}));
  const vals=Object.values(days);
  const cfg={
    type:'bar',
    data:{labels,datasets:[{data:vals,backgroundColor:'rgba(74,158,255,.2)',borderColor:'#4A9EFF',borderWidth:1.5,borderRadius:4,hoverBackgroundColor:'rgba(74,158,255,.45)'}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#0F1219',borderColor:'#4A9EFF',borderWidth:1,titleColor:'#E0E8F4',bodyColor:'#6A7890'}},scales:{x:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#3A4260',font:{family:'DM Mono',size:9},maxTicksLimit:8}},y:{grid:{color:'rgba(255,255,255,.04)'},ticks:{color:'#3A4260',font:{family:'DM Mono',size:9}},beginAtZero:true}}}
  };
  if(chartD){chartD.data=cfg.data;chartD.update();}
  else chartD=new Chart(document.getElementById('cd'),cfg);
}

// TABLE
function doTable(d){
  document.getElementById('tc').textContent=d.length+' total';
  const now=Date.now();
  let h='<table class="dt"><thead><tr><th>Quand</th><th>Pays</th><th>Ville</th><th>Version</th><th>User</th></tr></thead><tbody>';
  d.slice(0,40).forEach(r=>{
    const diff=Math.floor((now-new Date(r.launched_at||0))/1000);
    const when=diff<60?diff+'s':diff<3600?Math.floor(diff/60)+'min':diff<86400?Math.floor(diff/3600)+'h':Math.floor(diff/86400)+'j';
    const flag=FLAGS[r.country_code||'']||'🌐';
    const recent=diff<86400;
    h+='<tr>'
      +'<td><span class="pill '+(recent?'pg':'pb')+'">'+when+'</span></td>'
      +'<td>'+flag+' '+(r.country||'—')+'</td>'
      +'<td style="color:var(--t3)">'+(r.city||'—')+'</td>'
      +'<td><span class="pill pb">'+(r.version||'?')+'</span></td>'
      +'<td style="font-size:10px;color:var(--t3)">'+(r.user_id||'').slice(0,10)+'…</td>'
      +'</tr>';
  });
  h+='</tbody></table>';
  document.getElementById('tw').innerHTML=h;
}

// COUNTRIES
function doCountries(d){
  const counts={};
  d.forEach(r=>{
    const code=r.country_code||'??';
    const name=r.country||'Inconnu';
    if(!counts[code])counts[code]={n:0,name:name,flag:FLAGS[code]||'🌐'};
    counts[code].n++;
  });
  const sorted=Object.values(counts).sort((a,b)=>b.n-a.n).slice(0,6);
  const total=d.length||1;
  const colors=['#4A9EFF','#00C896','#FFB800','#FF4D6A','#A78BFA','#F97316'];
  if(!sorted.length){document.getElementById('cl').innerHTML='<div class="empty">Relance le logiciel pour obtenir les pays</div>';return;}
  let h='';
  sorted.forEach((c,i)=>{
    const pct=Math.round(c.n/total*100);
    h+='<div class="bi"><div class="bn">'+c.flag+' '+c.name+'</div><div class="bt"><div class="bf" style="width:'+pct+'%;background:'+colors[i]+'"></div></div><div class="bp">'+pct+'%</div></div>';
  });
  document.getElementById('cl').innerHTML=h;
}

// OS
function doOS(d){
  const os={};
  d.forEach(r=>{
    let l=r.os||'';
    if(!l)l='Inconnu';
    else if(l.includes('26')||l.includes('22631')||l.includes('22000'))l='Windows 11';
    else if(l.includes('19041')||l.includes('19042')||l.includes('19043')||l.includes('19044')||l.includes('19045'))l='Windows 10';
    else if(l.includes('10.0'))l='Windows 10/11';
    else l=l.slice(0,18);
    os[l]=(os[l]||0)+1;
  });
  const ram={};
  d.forEach(r=>{if(r.ram&&r.ram!=='?')ram[r.ram]=(ram[r.ram]||0)+1;});
  const total=d.length||1;
  const colors=['#4A9EFF','#00C896','#FFB800','#A78BFA','#FF4D6A'];
  let h='';
  Object.entries(os).sort((a,b)=>b[1]-a[1]).slice(0,4).forEach(([n,v],i)=>{
    const p=Math.round(v/total*100);
    h+='<div class="bi"><div class="bn">'+n+'</div><div class="bt"><div class="bf" style="width:'+p+'%;background:'+colors[i]+'"></div></div><div class="bp">'+p+'%</div></div>';
  });
  const ramEntries=Object.entries(ram).sort((a,b)=>b[1]-a[1]).slice(0,3);
  if(ramEntries.length){
    h+='<div style="margin:12px 0 8px;font-family:var(--fm);font-size:9px;color:var(--t3);letter-spacing:.08em;border-top:1px solid var(--b);padding-top:12px">RAM</div>';
    ramEntries.forEach(([n,v])=>{
      const p=Math.round(v/total*100);
      h+='<div class="bi"><div class="bn">'+n+'</div><div class="bt"><div class="bf" style="width:'+p+'%;background:var(--pu)"></div></div><div class="bp">'+p+'%</div></div>';
    });
  }
  document.getElementById('ol').innerHTML=h||'<div class="empty">Relance le logiciel pour obtenir les données</div>';
}

// DETAIL TABLE
function doDetail(d){
  const uniq={};
  d.forEach(r=>{if(r.user_id&&!uniq[r.user_id])uniq[r.user_id]=r;});
  const users=Object.values(uniq).sort((a,b)=>new Date(b.launched_at)-new Date(a.launched_at));
  if(!users.length){document.getElementById('dl').innerHTML='<div class="empty">Aucune donnée</div>';return;}
  let h='<table class="dt"><thead><tr><th>User ID</th><th>Hostname</th><th>Username</th><th>IP</th><th>Pays</th><th>Ville</th><th>OS</th><th>RAM</th><th>CPU</th><th>Langue</th><th>Date</th></tr></thead><tbody>';
  users.forEach(r=>{
    const flag=FLAGS[r.country_code||'']||'🌐';
    h+='<tr>'
      +'<td style="font-size:10px;color:var(--t3)">'+(r.user_id||'').slice(0,12)+'…</td>'
      +'<td style="color:var(--t)">'+(r.hostname||'—')+'</td>'
      +'<td style="color:var(--bl)">'+(r.username||'—')+'</td>'
      +'<td style="font-size:10px">'+(r.ip||'—')+'</td>'
      +'<td>'+flag+' '+(r.country||'—')+'</td>'
      +'<td style="color:var(--t3)">'+(r.city||'—')+'</td>'
      +'<td style="font-size:10px">'+(r.os||'—').slice(0,20)+'</td>'
      +'<td><span class="pill pb">'+(r.ram||'—')+'</span></td>'
      +'<td style="color:var(--t3)">'+(r.cpu_cores?r.cpu_cores+' cores':'—')+'</td>'
      +'<td style="font-size:10px">'+(r.language||'—')+'</td>'
      +'<td style="color:var(--t3);font-size:10px">'+new Date(r.launched_at||0).toLocaleDateString('fr-FR')+'</td>'
      +'</tr>';
  });
  h+='</tbody></table>';
  document.getElementById('dl').innerHTML=h;
}

// GLOBE
let gScene,gCam,gRen,gGroup,gDots=[];

function ll2v(lat,lon,r){
  const phi=(90-lat)*Math.PI/180;
  // +180 offset to match texture.offset.x=0.5 shift
  const theta=(lon)*Math.PI/180;
  return new THREE.Vector3(-r*Math.sin(phi)*Math.cos(theta),r*Math.cos(phi),r*Math.sin(phi)*Math.sin(theta));
}

function initGlobe(){
  const wrap=document.getElementById('gw');
  const W=wrap.clientWidth, H=wrap.clientHeight||320;
  gScene=new THREE.Scene();
  gCam=new THREE.PerspectiveCamera(45,W/H,0.1,1000);
  gCam.position.z=2.8;
  gRen=new THREE.WebGLRenderer({canvas:document.getElementById('gc'),alpha:true,antialias:true});
  gRen.setSize(W,H);
  gRen.setPixelRatio(Math.min(window.devicePixelRatio,2));
  gRen.setClearColor(0x000000,0);
  gGroup=new THREE.Group();
  gScene.add(gGroup);

  // Build Earth texture — proper equirectangular projection
// ── Load real Earth texture from NASA blue marble (public domain) ──
  const loader = new THREE.TextureLoader();
  // Use a reliable public equirectangular Earth texture
  const earthTexUrl = 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/23/Blue_Marble_2002.png/1280px-Blue_Marble_2002.png';

  // While texture loads, show a nice procedural placeholder
  const tmpCanvas = document.createElement('canvas');
  tmpCanvas.width = 512; tmpCanvas.height = 256;
  const tc = tmpCanvas.getContext('2d');
  tc.fillStyle = '#071422'; tc.fillRect(0,0,512,256);
  tc.strokeStyle = 'rgba(74,158,255,.12)'; tc.lineWidth = 1;
  for(let lat=-80;lat<=80;lat+=20){tc.beginPath();tc.moveTo(0,(90-lat)/180*256);tc.lineTo(512,(90-lat)/180*256);tc.stroke();}
  for(let lon=-160;lon<=180;lon+=20){tc.beginPath();tc.moveTo((lon+180)/360*512,0);tc.lineTo((lon+180)/360*512,256);tc.stroke();}
  const tmpTex = new THREE.CanvasTexture(tmpCanvas);

  const earthMat = new THREE.MeshPhongMaterial({
    map: tmpTex,
    specular: new THREE.Color(0x112244),
    shininess: 8
  });
  const earthMesh = new THREE.Mesh(new THREE.SphereGeometry(1, 64, 64), earthMat);
  gGroup.add(earthMesh);

  // Load real texture and swap when ready
  loader.load(
    earthTexUrl,
    function(texture) {
      // Fix texture orientation for Three.js sphere
      texture.wrapS = THREE.RepeatWrapping;
      texture.offset.x = 0.5; // shift 180° so lon 0 = center
      earthMat.map = texture;
      earthMat.needsUpdate = true;
    },
    undefined,
    function() {
      // Fallback: draw continents procedurally with correct UV offset
      const fb = document.createElement('canvas');
      fb.width = 2048; fb.height = 1024;
      const fc = fb.getContext('2d');
      // Ocean
      fc.fillStyle = '#071422'; fc.fillRect(0,0,2048,1024);
      // THREE.js sphere: u=0 at lon=-180, u=1 at lon=180
      // BUT the mesh starts at lon=180 and wraps, so offset by 0.5
      // To match: px = ((lon + 180) / 360) * 2048
      function px(lon){ return ((lon+180)/360)*2048; }
      function py(lat){ return ((90-lat)/180)*1024; }
      function fill(pts,col){
        fc.beginPath();
        fc.moveTo(px(pts[0][0]),py(pts[0][1]));
        for(let i=1;i<pts.length;i++)fc.lineTo(px(pts[i][0]),py(pts[i][1]));
        fc.closePath();fc.fillStyle=col;fc.fill();
        fc.strokeStyle='rgba(100,180,255,.2)';fc.lineWidth=2;fc.stroke();
      }
      fill([[-140,72],[-82,65],[-78,52],[-55,50],[-52,42],[-70,40],[-76,35],[-80,25],[-88,17],[-77,8],[-75,10],[-67,18],[-77,25],[-76,35],[-74,40],[-55,50],[-64,60],[-52,70],[-62,76],[-87,80],[-110,82],[-135,80],[-140,72]],'#15304A');
      fill([[-18,83],[-58,76],[-52,65],[-43,65],[-20,75],[-18,83]],'#122840');
      fill([[-75,10],[-62,8],[-50,0],[-35,-5],[-43,-23],[-58,-38],[-68,-52],[-67,-55],[-73,-52],[-71,-33],[-37,-10],[-52,5],[-75,10]],'#1C3A56');
      fill([[-8,36],[5,36],[10,44],[20,55],[28,71],[26,68],[16,68],[14,64],[8,60],[5,58],[8,56],[10,58],[18,60],[26,70],[28,71],[30,60],[20,54],[18,52],[15,52],[10,54],[8,56],[4,54],[5,52],[2,51],[-2,52],[-5,44],[-8,36]],'#15304A');
      fill([[38,38],[55,38],[70,40],[80,42],[100,36],[110,32],[120,38],[130,42],[140,46],[142,52],[140,58],[120,58],[100,62],[80,62],[62,50],[50,44],[40,42],[38,38]],'#14263E');
      fill([[30,70],[38,70],[100,70],[140,70],[160,62],[170,62],[160,52],[140,58],[120,58],[100,62],[80,62],[62,50],[50,44],[40,42],[38,38],[28,42],[26,38],[42,38],[55,38],[70,40],[73,80],[65,142],[55,135],[44,135],[35,139],[22,114],[5,100],[-5,105],[10,80],[25,55],[28,34],[42,38],[70,40],[80,50],[80,60],[70,60],[62,100],[62,80],[70,40]],'#14263E');
      fill([[-8,4],[-18,16],[-16,12],[-15,5],[-10,-4],[-18,-35],[-26,-34],[-32,-30],[18,-35],[36,-22],[42,-12],[44,0],[42,12],[42,22],[36,38],[30,30],[24,22],[18,16],[10,10],[2,4],[-8,4]],'#1C3A56');
      fill([[128,-15],[141,-12],[153,-26],[146,-38],[140,-38],[124,-32],[122,-18],[128,-15]],'#1C3A56');
      // Grid
      fc.strokeStyle='rgba(74,158,255,.08)';fc.lineWidth=1;
      for(let lat=-80;lat<=80;lat+=20){fc.beginPath();fc.moveTo(0,py(lat));fc.lineTo(2048,py(lat));fc.stroke();}
      for(let lon=-160;lon<=180;lon+=20){fc.beginPath();fc.moveTo(px(lon),0);fc.lineTo(px(lon),1024);fc.stroke();}
      const fbTex=new THREE.CanvasTexture(fb);
      fbTex.wrapS=THREE.RepeatWrapping;
      fbTex.offset.x=0.5;
      earthMat.map=fbTex;
      earthMat.needsUpdate=true;
    }
  );


  // Lighting
  gScene.add(new THREE.AmbientLight(0x2244AA, 1.5));
  const sun = new THREE.DirectionalLight(0xAABBFF, 1.3);
  sun.position.set(5, 2, 5);
  gScene.add(sun);

  // Atmosphere
  gGroup.add(new THREE.Mesh(
    new THREE.SphereGeometry(1.07,32,32),
    new THREE.MeshBasicMaterial({color:0x2255AA,transparent:true,opacity:.07,side:THREE.BackSide})
  ));

  let drag=false,pm={x:0,y:0};
  const cv=document.getElementById('gc');
  cv.addEventListener('mousedown',e=>{drag=true;pm={x:e.clientX,y:e.clientY};});
  window.addEventListener('mouseup',()=>drag=false);
  window.addEventListener('mousemove',e=>{
    if(!drag)return;
    gGroup.rotation.y+=(e.clientX-pm.x)*.005;
    gGroup.rotation.x+=(e.clientY-pm.y)*.005;
    pm={x:e.clientX,y:e.clientY};
  });
  // Touch support
  cv.addEventListener('touchstart',e=>{drag=true;pm={x:e.touches[0].clientX,y:e.touches[0].clientY};});
  cv.addEventListener('touchend',()=>drag=false);
  cv.addEventListener('touchmove',e=>{
    if(!drag)return;
    gGroup.rotation.y+=(e.touches[0].clientX-pm.x)*.005;
    gGroup.rotation.x+=(e.touches[0].clientY-pm.y)*.005;
    pm={x:e.touches[0].clientX,y:e.touches[0].clientY};
  });

  (function anim(){
    requestAnimationFrame(anim);
    if(!drag)gGroup.rotation.y+=.0012;
    gRen.render(gScene,gCam);
  })();

  window.addEventListener('resize',()=>{
    const W2=wrap.clientWidth,H2=wrap.clientHeight||320;
    gCam.aspect=W2/H2;gCam.updateProjectionMatrix();
    gRen.setSize(W2,H2);
  });
}

function doGlobe(d){
  gDots.forEach(m=>gGroup.remove(m));
  gDots=[];
  const now=Date.now();
  const by={};
  d.forEach(r=>{
    const c=r.country_code;
    if(!c)return;
    if(!by[c])by[c]={n:0,last:0};
    by[c].n++;
    const t=new Date(r.launched_at||0).getTime();
    if(t>by[c].last)by[c].last=t;
  });
  let cnt=0;
  Object.entries(by).forEach(([code,info])=>{
    const coords=COORDS[code];
    if(!coords)return;
    const recent=(now-info.last)<86400000;
    const color=recent?0x00C896:0x4A9EFF;
    const size=Math.min(.018+info.n*.004,.055);
    const dot=new THREE.Mesh(new THREE.SphereGeometry(size,10,10),new THREE.MeshBasicMaterial({color}));
    const pos=ll2v(coords[0],coords[1],1.018);
    dot.position.copy(pos);
    gGroup.add(dot);
    gDots.push(dot);
    // Glow halo
    const halo=new THREE.Mesh(new THREE.SphereGeometry(size*2.2,8,8),new THREE.MeshBasicMaterial({color,transparent:true,opacity:.15}));
    halo.position.copy(pos);
    gGroup.add(halo);
    gDots.push(halo);
    if(recent){
      const ring=new THREE.Mesh(new THREE.RingGeometry(size*2,size*3,16),new THREE.MeshBasicMaterial({color:0x00C896,transparent:true,opacity:.6,side:THREE.DoubleSide}));
      ring.position.copy(pos);
      ring.lookAt(0,0,0);
      gGroup.add(ring);
      gDots.push(ring);
    }
    cnt++;
  });
  document.getElementById('gcnt').textContent=cnt+' pays actifs';
  // Render country labels on 2D overlay canvas
  renderGlobeLabels(by);
}

window.addEventListener('load',()=>{
  // Wait for app to be visible and globe wrap to have real dimensions
  const tryInit = () => {
    const wrap = document.getElementById('gw');
    if(!wrap) return setTimeout(tryInit, 100);
    const W = wrap.clientWidth;
    const H = wrap.clientHeight;
    if(W < 10 || H < 10) return setTimeout(tryInit, 100);
    initGlobe();
  };
  setTimeout(tryInit, 300);
});

let _globeBy={};
function renderGlobeLabels(by){
  if(by)_globeBy=by;
  const lc=document.getElementById('glabels');
  if(!lc||!gRen||!gCam||!gGroup)return;
  const wrap=document.getElementById('gw');
  const W=wrap.clientWidth, H=wrap.clientHeight||320;
  if(lc.width!==W){lc.width=W;lc.height=H;}
  const ctx=lc.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const now=Date.now();
  // Collect all visible points with screen positions
  const pts=[];
  Object.entries(_globeBy).forEach(([code,info])=>{
    const coords=COORDS[code];
    if(!coords)return;
    const pos3=ll2v(coords[0],coords[1],1.05).clone();
    pos3.applyEuler(gGroup.rotation);
    const v=pos3.clone().project(gCam);
    if(v.z>0.98)return; // back face culling
    const x=(v.x*.5+.5)*W;
    const y=(-.5*v.y+.5)*H;
    if(x<10||x>W-10||y<10||y>H-10)return;
    pts.push({code,info,x,y,recent:(now-info.last)<86400000});
  });

  // Smart label placement — avoid overlaps
  // Sort by importance (recent first, then by count)
  pts.sort((a,b)=>(b.recent-a.recent)||b.info.n-a.info.n);
  const placed=[];
  const LABEL_W=52, LABEL_H=18, MIN_DIST=60;

  pts.forEach(p=>{
    const flag=FLAGS[p.code]||'';
    const col=p.recent?'#00C896':'#90C8FF';
    const alpha=p.recent?1:.8;

    // Check distance from already placed labels
    const tooClose=placed.some(q=>Math.hypot(p.x-q.x,p.y-q.y)<MIN_DIST);

    // Draw dot always
    ctx.beginPath();
    ctx.arc(p.x,p.y,p.recent?5:3.5,0,Math.PI*2);
    ctx.fillStyle=col;
    ctx.globalAlpha=alpha;
    ctx.fill();
    ctx.globalAlpha=1;

    // Draw pulse ring for recent
    if(p.recent){
      ctx.beginPath();
      ctx.arc(p.x,p.y,9,0,Math.PI*2);
      ctx.strokeStyle='rgba(0,200,150,.4)';
      ctx.lineWidth=1.5;
      ctx.stroke();
    }

    // Draw label only if not too close to another
    if(!tooClose){
      ctx.font='bold 10px DM Mono,monospace';
      ctx.textAlign='left';
      const label=flag+' '+p.code+(p.info.n>1?' ('+p.info.n+')':'');
      const tw=ctx.measureText(label).width+10;
      const lx=p.x+8, ly=p.y-4;
      // pill bg
      ctx.fillStyle='rgba(5,8,20,.82)';
      ctx.globalAlpha=.92;
      ctx.beginPath();
      if(ctx.roundRect) ctx.roundRect(lx-2,ly-11,tw,16,4);
      else ctx.rect(lx-2,ly-11,tw,16);
      ctx.fill();
      ctx.globalAlpha=1;
      // border
      ctx.strokeStyle=p.recent?'rgba(0,200,150,.5)':'rgba(74,158,255,.3)';
      ctx.lineWidth=.8;
      ctx.stroke();
      // text
      ctx.fillStyle=col;
      ctx.fillText(label,lx+2,ly+1);
      placed.push(p);
    }
  });
  requestAnimationFrame(()=>renderGlobeLabels(null));
}
